{
  "expo": {
    "name": "EcoBus",
    "slug": "ecobus-parents",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E1726"
    },
    "newArchEnabled": false,
    "android": {
      "package": "app.ecobus.parents",
      "versionCode": 1,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCG5E5SZLZYoEo3SQujz-oIlRk5WMGarQI"
        }
      }
    },
    "ios": {
      "bundleIdentifier": "app.ecobus.parents",
      "buildNumber": "1",
      "deploymentTarget": "15.1",
      "supportsTablet": true,
      "requiresFullScreen": false,
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": "AIzaSyCG5E5SZLZYoEo3SQujz-oIlRk5WMGarQI"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "EcoBus uses your location only to center the live bus tracking map on your area. You can deny this and still use the app — the map will use a default region.",
        "NSCameraUsageDescription": "EcoBus does not use your camera. This permission is only present because a third-party SDK requires the description string.",
        "NSPhotoLibraryUsageDescription": "EcoBus does not access your photos. This permission is only present because a third-party SDK requires the description string.",
        "NSMicrophoneUsageDescription": "EcoBus does not record audio.",
        "NSContactsUsageDescription": "EcoBus does not access your contacts.",
        "NSUserTrackingUsageDescription": "EcoBus does not track you across other apps or websites.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "privacyPolicyUrl": "https://ecobus.app/privacy",
    "plugins": [
      "expo-localization",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "useLegacyPackaging": false
          },
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "REPLACE_WITH_EXPO_ACCOUNT"
  }
}
