# Public runtime config — safe to commit (used by the JS bundle).
# Copy to .env for local dev. EAS reads env from eas.json per profile.
EXPO_PUBLIC_API_BASE_URL=https://busapi.ihebchebbi.pro
APP_ENV=development

# Google Maps key is hardcoded in app.json (android.config.googleMaps.apiKey
# and ios.config.googleMapsApiKey). Restrict it in Google Cloud Console by
# package + SHA-1 (Android) and bundle id (iOS).
