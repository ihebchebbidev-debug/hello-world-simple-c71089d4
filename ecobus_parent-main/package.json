{
  "name": "ecobus-parents",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "lint": "eslint .",
    "check:i18n": "node scripts/check-i18n.js",
    "build:android:apk": "eas build -p android --profile preview",
    "build:android:apk:prod": "eas build -p android --profile production-apk",
    "build:android:aab": "eas build -p android --profile production",
    "build:ios:preview": "eas build -p ios --profile preview",
    "build:ios:simulator": "eas build -p ios --profile preview-simulator",
    "build:ios:prod": "eas build -p ios --profile production",
    "build:all:preview": "eas build --platform all --profile preview",
    "build:all:prod": "eas build --platform all --profile production",
    "submit:android": "eas submit -p android --latest",
    "submit:ios": "eas submit -p ios --latest",
    "credentials:android": "eas credentials -p android",
    "credentials:ios": "eas credentials -p ios",
    "local:android:release": "cd android && ./gradlew clean assembleRelease",
    "local:android:bundle": "cd android && ./gradlew clean bundleRelease"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "axios": "^1.7.7",
    "expo": "^55.0.19",
    "expo-device": "~55.0.15",
    "expo-localization": "^55.0.13",
    "expo-notifications": "~55.0.22",
    "i18next": "^26.0.8",
    "react": "^19.2.0",
    "react-i18next": "^17.0.6",
    "react-native": "^0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "^1.27.2",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.85.2",
    "express": "^5.2.1"
  }
}
