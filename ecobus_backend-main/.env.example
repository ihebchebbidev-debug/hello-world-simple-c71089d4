# =====================================================================
# EcoBus V2 — Backend environment
# Copy this file to `.env` and fill in real values.
# Lines starting with `#` are comments.
# =======================================================j==============

# ---------- Server ----------
NODE_ENV=development            # development | production | test
PORT=4000                       # HTTP port the API listens on
API_PREFIX=/api/v1              # All routes are mounted under this prefix

# ---------- PostgreSQL ----------
# Standard libpq connection string. Examples:
#   Local docker:  postgres://postgres:postgres@localhost:5432/ecobus
#   Neon:          postgresql://USER:PASS@ep-xxx.eu-central-1.aws.neon.tech/ecobus?sslmode=require
#   Supabase:      postgresql://postgres:PASS@db.xxx.supabase.co:5432/postgres
#   Render:        postgresql://USER:PASS@dpg-xxx.oregon-postgres.render.com/ecobus
#   Railway:       postgresql://postgres:PASS@containers-us-west-x.railway.app:6543/railway
#   Heroku:        postgres://USER:PASS@ec2-xx.compute-1.amazonaws.com:5432/db
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecobus

# SSL is auto-detected:
#   - On if the URL contains `?sslmode=require` (or any non-`disable` mode)
#   - On for known managed hosts (Neon, Supabase, Render, Railway, Heroku, RDS, …)
#   - Off for localhost / docker network
# Override explicitly with PGSSL=true|false. Set PGSSL_STRICT=true to enforce
# certificate verification (most managed providers fail strict — leave false).
# PGSSL=true
# PGSSL_STRICT=false

# Connection pool size (per Node process)
PG_POOL_MAX=20

# ---------- Auth ----------
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ---------- CORS ----------
# Comma-separated list of allowed origins, or `*` for any.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX=300              # requests per window per IP

# ---------- Logging ----------
LOG_LEVEL=info                  # error | warn | info | http | debug
LOG_DIR=./logs                  # where rotating JSON log files are written
# Token required to read /api/v1/logs/* — set to a long random string.
LOG_VIEWER_TOKEN=change-me-to-a-long-random-string

# ---------- Auto-migration ----------
# When true (default), pending SQL migrations in migrations/sql/ run on boot.
AUTO_MIGRATE=true

# ---------- GitHub auto-sync (optional) ----------
# When enabled the container periodically pulls the latest commit on a branch
# and re-runs migrations so DB schema follows the repo.
GIT_SYNC_ENABLED=false
# For private repos embed a fine-grained PAT:
#   https://x-access-token:<TOKEN>@github.com/owner/repo.git
GIT_SYNC_REPO=
GIT_SYNC_BRANCH=main
GIT_SYNC_DIR=/app/repo
GIT_SYNC_INTERVAL_MS=60000

# ---------- Twilio SMS (Phone OTP for parents & drivers) ----------
# All phone numbers are normalized to E.164 with Tunisia country code (+216)
# when the caller sends a local 8-digit number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use either a Twilio phone number (E.164, e.g. +1XXXXXXXXXX) ...
TWILIO_FROM=
# ...OR a Messaging Service SID (preferred — recommended for deliverability)
TWILIO_MESSAGING_SERVICE_SID=
# Default country code (digits, no '+'). Tunisia = 216
OTP_DEFAULT_CC=216
