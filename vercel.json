{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": "dist",
  "framework": null,
  "env": {
    "VITE_VERCEL_BUILD": "true"
  },
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://hello-world-simple-c71089d4.onrender.com/:path*",
      "permanent": false
    }
  ]
}
